# Pick the generator backend: openai | codex | fake
GENERATOR=openai

# --- OpenAI generator ---
OPENAI_API_KEY=your_openai_api_key_here
# Model used for the agent loop. Anything that supports tool/function calling
# and image inputs works. Run `npm run check` to see which models your key
# actually has access to.
#   gpt-5.5         — current flagship (released 2026-04-23). Pricey.
#   gpt-5.4-mini    — cheaper, much faster.
#   gpt-4.1 / 4o    — older but widely available.
OPENAI_MODEL=gpt-5.5
# Max tool-call iterations per spawn. The user expects 1–10 minute renders so
# this is set generously.
OPENAI_MAX_STEPS=80

# --- Blender MCP server ---
# Command + args used to launch the MCP server. Defaults are correct for the
# standard `uvx blender-mcp` install.
MCP_CMD=uvx
MCP_ARGS=blender-mcp
# Optional. Set these when the Node app runs somewhere different from Blender.
# Example: Node in WSL + Blender on Windows should use the Windows WSL gateway IP.
# BLENDER_HOST=172.17.112.1
# BLENDER_PORT=9876

# --- Per-job timeout (applies to all generators) ---
CODEX_TIMEOUT_MS=900000

# --- Codex generator (only if GENERATOR=codex) ---
# CODEX_CMD=codex

# --- Fake generator (instant placeholders, no Blender required) ---
# FAKE_GENERATOR=1
# FAKE_DELAY_SEC=3

# --- Server ---
PORT=3000
