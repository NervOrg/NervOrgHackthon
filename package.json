{
  "name": "edu3d",
  "version": "0.1.0",
  "description": "Browser-based 3D NPC maker world. Maker mode spawns AI-generated NPCs via Codex + Blender MCP. Play mode walks around and talks to them.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:codex": "node scripts/run-with-env.mjs GENERATOR=codex -- node server.js",
    "dev": "node scripts/run-with-env.mjs FAKE_GENERATOR=1 -- node server.js",
    "check": "node scripts/check-openai.mjs",
    "check:mcp": "node scripts/check-mcp.mjs",
    "check:generation-contract": "node scripts/check-generation-contract.mjs",
    "check:integration-guardrails": "node scripts/check-integration-guardrails.mjs",
    "check:part-manifest": "node scripts/check-part-manifest.mjs",
    "test:quality": "node scripts/test-generation-quality.mjs",
    "apply:sketchfab": "node scripts/apply-sketchfab-key.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "async-mutex": "^0.5.0",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "openai": "^6.35.0",
    "uuid": "^9.0.1",
    "ws": "^8.17.0"
  }
}
