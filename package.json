    "check": "node scripts/check-openai.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "async-mutex": "^0.5.0",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "openai": "^6.35.0",
    "uuid": "^9.0.1",
    "ws": "^8.17.0"
  }
}
